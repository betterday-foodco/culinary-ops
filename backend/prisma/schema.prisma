generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String   @id @default(uuid())
  email         String   @unique
  password_hash String
  role          String   @default("staff")  // "admin" | "staff" | "kitchen"
  name          String?                      // display name, required for kitchen staff
  station       String?                      // kitchen role only — one of the 6 fixed station names
  created_at    DateTime @default(now())

  production_logs    KitchenProductionLog[]
  feedback_entries   KitchenFeedback[]
  station_requests   StationRequest[]
  created_tasks      StationTask[]  @relation("CreatedStationTasks")
  assigned_tasks     StationTask[]  @relation("AssignedStationTasks")
  completed_tasks    StationTask[]  @relation("CompletedStationTasks")
  sent_messages      KitchenMessage[] @relation("SentMessages")
  received_messages  KitchenMessage[] @relation("ReceivedMessages")
  approved_shortages KitchenProductionLog[] @relation("ApprovedShortages")
}

model Ingredient {
  id             String   @id @default(uuid())
  internal_name  String
  display_name   String
  sku            String   @unique
  category       String
  location       String?
  supplier_name  String?
  trim_percentage Float   @default(0)
  base_weight    Float    @default(1)
  cost_per_unit  Float    @default(0)
  unit           String   @default("Kgs")
  stock          Float    @default(0)       // current on-hand quantity (in ingredient's unit)
  allergen_tags  String[]
  benefits       String[]
  is_active      Boolean  @default(true)
  created_at     DateTime @default(now())
  updated_at     DateTime @updatedAt

  sub_recipe_components SubRecipeComponent[]
  meal_components       MealComponent[]

  @@index([sku])
  @@index([category])
}

model SubRecipe {
  id               String   @id @default(uuid())
  name             String
  display_name     String?
  sub_recipe_code  String   @unique
  instructions     String?
  production_day   String?
  station_tag      String?
  priority         Int      @default(3)
  base_yield_weight Float   @default(1)
  base_yield_unit   String  @default("Kgs")
  computed_cost    Float    @default(0)
  is_active        Boolean  @default(true)
  created_at       DateTime @default(now())
  updated_at       DateTime @updatedAt

  components        SubRecipeComponent[] @relation("SubRecipeComponents")
  parent_components SubRecipeComponent[] @relation("ChildSubRecipe")
  meal_components   MealComponent[]
  kitchen_logs      KitchenProductionLog[]
  feedback          KitchenFeedback[]
  station_requests  StationRequest[]

  @@index([sub_recipe_code])
  @@index([station_tag])
  @@index([priority])
}

model SubRecipeComponent {
  id                  String     @id @default(uuid())
  sub_recipe_id       String
  ingredient_id       String?
  child_sub_recipe_id String?
  quantity            Float
  unit                String     @default("Kgs")
  trim_percentage     Float      @default(0)

  sub_recipe          SubRecipe  @relation("SubRecipeComponents", fields: [sub_recipe_id], references: [id], onDelete: Cascade)
  ingredient          Ingredient? @relation(fields: [ingredient_id], references: [id])
  child_sub_recipe    SubRecipe?  @relation("ChildSubRecipe", fields: [child_sub_recipe_id], references: [id])
}

model MealRecipe {
  id                    String   @id @default(uuid())
  name                  String
  display_name          String
  category              String?
  linked_meal_id        String?  // points to the meat/vegan counterpart
  final_yield_weight    Float    @default(0)
  pricing_override      Float?
  computed_cost         Float    @default(0)
  allergen_tags          String[]
  dislikes               String[]
  heating_instructions   String?
  packaging_instructions String?
  cooking_instructions   String?
  description            String?
  short_description      String?
  image_url              String?
  net_weight_kg          Float    @default(0)
  calories               Int?
  protein_g              Float?
  carbs_g                Float?
  fat_g                  Float?
  fiber_g                Float?
  shelf_life_days        Int?
  label_ingredients      String?  // comma-separated label text for product label
  protein_types          String[] // e.g. ["Chicken", "Turkey"]
  dietary_tags           String[] // e.g. ["Gluten Friendly", "High Protein", "Vegan"]
  starch_type            String?  // "Rice" | "Pasta" | "Potato" | "Quinoa" | "Other" | "None"
  container_type         String?  // "Meal Tray" | "Salad Container"
  portion_score          Int?     // 1–4 scale
  is_active              Boolean  @default(true)
  created_at            DateTime @default(now())
  updated_at            DateTime @updatedAt

  linked_meal           MealRecipe?  @relation("MealVariants", fields: [linked_meal_id], references: [id], onDelete: SetNull)
  variant_meals         MealRecipe[] @relation("MealVariants")
  components            MealComponent[]
  orders                Order[]
  production_plan_items ProductionPlanItem[]
  menu_queue_items      MenuQueueItem[]

  @@index([name])
  @@index([category])
  @@index([linked_meal_id])
}

model MealComponent {
  id             String      @id @default(uuid())
  meal_id        String
  ingredient_id  String?
  sub_recipe_id  String?
  quantity       Float
  unit           String      @default("gr")

  meal           MealRecipe  @relation(fields: [meal_id], references: [id], onDelete: Cascade)
  ingredient     Ingredient? @relation(fields: [ingredient_id], references: [id])
  sub_recipe     SubRecipe?  @relation(fields: [sub_recipe_id], references: [id])
}

model Order {
  id                String   @id @default(uuid())
  external_order_id String   @unique
  meal_id           String
  quantity          Int
  production_date   DateTime
  source_platform   String   @default("shopify")
  created_at        DateTime @default(now())

  meal MealRecipe @relation(fields: [meal_id], references: [id])

  @@index([production_date])
  @@index([meal_id])
  @@index([external_order_id])
}

model ProductionPlan {
  id                   String   @id @default(uuid())
  week_label           String
  week_start           DateTime
  status               String   @default("draft")
  notes                String?
  published_to_kitchen Boolean  @default(false)
  created_at           DateTime @default(now())
  updated_at           DateTime @updatedAt

  items            ProductionPlanItem[]
  kitchen_logs     KitchenProductionLog[]
  station_requests StationRequest[]
  station_tasks    StationTask[]

  @@index([week_start])
}

model ProductionPlanItem {
  id       String @id @default(uuid())
  plan_id  String
  meal_id  String
  quantity Int    @default(0)

  plan ProductionPlan @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  meal MealRecipe     @relation(fields: [meal_id], references: [id])

  @@unique([plan_id, meal_id])
}

model KitchenProductionLog {
  id              String   @id @default(uuid())
  plan_id         String
  sub_recipe_id   String
  user_id         String
  status          String   @default("not_started") // not_started | in_progress | done | short
  qty_cooked      Float?
  weight_recorded Float?
  have_on_hand    Float?   // qty already available (reduces required cook amount)
  notes           String?
  cooked_by       String?   // freetext: who actually cooked it
  shortage_approved         Boolean   @default(false)
  shortage_approved_by_id   String?
  shortage_approved_at      DateTime?
  logged_at       DateTime @default(now())
  updated_at      DateTime @updatedAt

  plan                    ProductionPlan @relation(fields: [plan_id], references: [id])
  sub_recipe              SubRecipe      @relation(fields: [sub_recipe_id], references: [id])
  user                    User           @relation(fields: [user_id], references: [id])
  shortage_approved_by    User?          @relation("ApprovedShortages", fields: [shortage_approved_by_id], references: [id])

  @@unique([plan_id, sub_recipe_id, user_id])
  @@index([plan_id])
}

model KitchenFeedback {
  id            String   @id @default(uuid())
  sub_recipe_id String
  user_id       String
  plan_id       String?
  rating        Int      // 1–5
  comment       String?
  admin_notes   String?  // chef/admin notes after reviewing feedback
  is_fixed      Boolean  @default(false)  // admin marks recipe as fixed
  created_at    DateTime @default(now())
  updated_at    DateTime @default(now()) @updatedAt

  sub_recipe SubRecipe @relation(fields: [sub_recipe_id], references: [id])
  user       User      @relation(fields: [user_id], references: [id])

  @@index([sub_recipe_id])
}

model StationRequest {
  id            String   @id @default(uuid())
  from_user_id  String
  to_station    String   // target station, e.g. "Sauce Station"
  plan_id       String?
  sub_recipe_id String?
  description   String
  quantity      Float?
  unit          String?
  status        String   @default("pending")  // pending | acknowledged | completed
  created_at    DateTime @default(now())
  updated_at    DateTime @updatedAt

  from_user  User            @relation(fields: [from_user_id], references: [id])
  plan       ProductionPlan? @relation(fields: [plan_id], references: [id])
  sub_recipe SubRecipe?      @relation(fields: [sub_recipe_id], references: [id])

  @@index([to_station])
  @@index([plan_id])
}

model MenuQueueItem {
  id              String   @id @default(uuid())
  column_id       String   // "meat_1".."meat_5", "omni_1".."omni_6", "vegan_1"
  meal_id         String
  position        Int      @default(0) // sort order within column; 0 = this week
  repeat_weeks    Int      @default(4) // after serving, goes back to end with this many weeks gap
  weeks_remaining Int      @default(0) // display only — 0 = on menu this week
  created_at      DateTime @default(now())
  updated_at      DateTime @updatedAt

  meal MealRecipe @relation(fields: [meal_id], references: [id], onDelete: Cascade)

  @@unique([column_id, meal_id])
  @@index([column_id])
}

model MenuAdvanceLog {
  id          String   @id @default(uuid())
  advanced_at DateTime @default(now())
  week_label  String?
  notes       String?
}

model StationTask {
  id               String    @id @default(uuid())
  plan_id          String?
  title            String
  description      String?
  station          String?          // null = show on all stations
  assigned_user_id String?          // null = all staff on that station
  completed_by_id  String?
  completed_at     DateTime?
  created_by_id    String
  created_at       DateTime  @default(now())
  updated_at       DateTime  @updatedAt

  plan          ProductionPlan? @relation(fields: [plan_id], references: [id], onDelete: Cascade)
  assigned_user User?           @relation("AssignedStationTasks", fields: [assigned_user_id], references: [id])
  completed_by  User?           @relation("CompletedStationTasks", fields: [completed_by_id], references: [id])
  created_by    User            @relation("CreatedStationTasks", fields: [created_by_id], references: [id])

  @@index([station])
  @@index([plan_id])
}

model KitchenMessage {
  id           String   @id @default(uuid())
  from_user_id String
  to_station   String?   // null = broadcast to all kitchen; specific = to that station only
  to_user_id   String?   // direct message to a specific user (e.g. chef)
  body         String
  is_read      Boolean  @default(false)
  created_at   DateTime @default(now())

  from_user User  @relation("SentMessages",     fields: [from_user_id], references: [id])
  to_user   User? @relation("ReceivedMessages", fields: [to_user_id],   references: [id])

  @@index([to_station])
  @@index([to_user_id])
  @@index([from_user_id])
}
