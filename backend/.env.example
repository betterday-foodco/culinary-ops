# ── Culinary database (Gurleen's project) ────────────────────────────────────
# Kitchen ops data — ingredients, recipes, meals, production, corporate B2B.
# Points at Gurleen's shared culinary-ops Neon project.
DATABASE_URL="postgresql://user:password@localhost:5432/culinary_ops"
# Prisma also needs a direct (non-pooled) URL for migrations:
DIRECT_URL="postgresql://user:password@localhost:5432/culinary_ops"

# ── Commerce database (BetterDay Food Co org) ────────────────────────────────
# Customer-facing data — customers, carts, orders, subscriptions, payments.
# Lives in a separate Neon project (betterday-commerce) per PROJECT_SCOPE.md §10.
# Locally this should point at the `dev` branch so migrations don't touch prod.
# On Render/production, override to the `main` branch connection string.
COMMERCE_DATABASE_URL="postgresql://user:password@host/neondb"
COMMERCE_DIRECT_URL="postgresql://user:password@host/neondb"

JWT_SECRET="change-this-to-a-strong-secret-key"
JWT_EXPIRATION="7d"
SHOPIFY_WEBHOOK_SECRET="your-shopify-webhook-secret"
PORT=3001
NODE_ENV=development

# CORS allow-list. Comma-separated origins that may call this API.
# Localhost ports are always allowed in dev.
FRONTEND_URL="http://localhost:3000"
# Optional multi-origin list (takes precedence over FRONTEND_URL if set):
# FRONTEND_URLS="https://culinary-ops-frontend.onrender.com,https://betterday-webapp.onrender.com"

# ── Corporate email (Resend) ──────────────────────────────────────────────────
# Get your API key at https://resend.com — set this in production to enable email
# Leave blank in dev — magic link tokens are returned directly in the API response
RESEND_API_KEY=""
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL="noreply@betterday.com.au"

# ── Payments (Helcim) ────────────────────────────────────────────────────────
# Card processing for the BetterDay commerce backend. See
# conner/data-model/helcim-integration.md for the full integration design and
# conner/data-model/helcim-integration-plan.md for the build plan.
#
# Sandbox vs production: same base URL (api.helcim.com/v2), different tokens.
# Sandbox tokens are issued by emailing tier2support@helcim.com with your
# existing Helcim merchant ID. Production tokens come from the Helcim
# dashboard → All Tools → Integrations → API Access Configurations.
#
# DO NOT put real values here — this file is committed. Real values go in
# backend/.env (gitignored) or Render's env var dashboard.
HELCIM_API_TOKEN=""
# Separate token from the API token — comes from Helcim dashboard → All Tools
# → Integrations → Webhooks. Must be base64-decoded before use as the HMAC
# signing key. See helcim-integration.md §7 for the verification algorithm.
HELCIM_WEBHOOK_VERIFIER_TOKEN=""
# Server public IP — fallback for the ipAddress field on merchant-initiated
# /v2/payment/purchase calls when no customer IP is available (Thursday
# cutoff cron has no customer session). On Render, this is the outbound
# egress IP of the service — find it in the Render dashboard under the
# service's Networking section, or curl https://api.ipify.org from within
# the running service. See helcim-integration.md §5 for the fallback chain.
SERVER_PUBLIC_IP=""
