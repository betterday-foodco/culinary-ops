DATABASE_URL="postgresql://user:password@localhost:5432/culinary_ops"
JWT_SECRET="change-this-to-a-strong-secret-key"
JWT_EXPIRATION="7d"
SHOPIFY_WEBHOOK_SECRET="your-shopify-webhook-secret"
PORT=3001
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# ── Corporate email (Resend) ──────────────────────────────────────────────────
# Get your API key at https://resend.com — set this in production to enable email
# Leave blank in dev — magic link tokens are returned directly in the API response
RESEND_API_KEY=""
# Must be a verified sender domain in your Resend account
RESEND_FROM_EMAIL="noreply@betterday.com.au"
